          "value": "={{ $json.spreadsheetId }}",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Sheet1",
          "mode": "list"
        },
        "columns": {
          "mappingMode": "autoMapInputData"
        },
        "options": {}
      },
      "id": "13",
      "name": "Google Sheets — Append Results",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [2220, 300],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "google-sheets",
          "name": "Google Sheets Account"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ {\n  \"status\": \"success\",\n  \"request_id\": $('Set — Context').first().json.request_id,\n  \"total_results\": $input.all().length,\n  \"top_10\": $input.all().slice(0, 10).map(item => ({\n    title: item.json.title,\n    image_url: item.json.image_url,\n    pinterest_url: item.json.pinterest_url,\n    relevance_score: item.json.relevance_score\n  })),\n  \"sheet_url\": $('Google Sheets — Create Sheet').first().json.spreadsheetUrl\n} }}",
        "options": {}
      },
      "id": "14",
      "name": "Respond — Success",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [2440, 300]
    }
